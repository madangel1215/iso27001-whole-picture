{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ISO 27001 Whole Picture data model",
  "type": "object",
  "required": ["meta", "architectures", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["standard", "version", "linkTypes"],
      "additionalProperties": true,
      "properties": {
        "standard": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "accent": { "type": "string" },
        "linkTypes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "architectures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "explanation", "layers"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9.\\-]+$" },
          "type": {
            "type": "string",
            "enum": ["clause", "control", "risk-step", "risk-technique", "bridge", "architecture", "lifecycle-stage"]
          },
          "ref": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "title_en": { "type": "string" },
          "summary": { "type": "string" },
          "explanation": { "type": "string", "minLength": 10 },
          "layers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "attributes": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "controlType": { "type": "array", "items": { "type": "string" } },
              "cia": {
                "type": "array",
                "items": { "type": "string", "enum": ["機密性", "完整性", "可用性"] }
              },
              "cyberConcept": { "type": "array", "items": { "type": "string" } },
              "operationalCapability": { "type": "array", "items": { "type": "string" } },
              "securityDomain": { "type": "array", "items": { "type": "string" } }
            }
          },
          "subconcepts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "rel"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "rel": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        }
      }
    }
  }
}
