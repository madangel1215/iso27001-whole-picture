{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ISO 27001 Whole Picture data model",
  "type": "object",
  "required": ["meta", "architectures", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["standard", "version", "linkTypes"],
      "additionalProperties": true,
      "properties": {
        "standard": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "accent": { "type": "string" },
        "linkTypes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "architectures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "explanation", "layers"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9.\\-]+$" },
          "type": {
            "type": "string",
            "enum": ["clause", "control", "risk-step", "risk-technique", "bridge", "lifecycle-stage", "cross-cutting-band"]
          },
          "ref": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "title_en": { "type": "string" },
          "summary": { "type": "string" },
          "explanation": { "type": "string", "minLength": 10 },
          "layers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "attributes": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "controlType": {
                "type": "array",
                "items": { "type": "string", "enum": ["預防", "偵測", "矯正"] }
              },
              "cia": {
                "type": "array",
                "items": { "type": "string", "enum": ["機密性", "完整性", "可用性"] }
              },
              "operationalCapability": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["治理", "資產管理", "資訊保護", "人力資源安全", "實體安全", "系統與網路安全", "應用系統安全", "安全組態", "身分與存取管理", "威脅與脆弱性管理", "持續運作", "供應者關係安全", "法規與合規", "資安事件管理", "資安保證"]
                }
              },
              "securityDomain": {
                "type": "array",
                "items": { "type": "string", "enum": ["治理與生態系", "保護", "防禦", "韌性"] }
              }
            }
          },
          "subconcepts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "note": { "type": "string" }
              }
            }
          },
          "audit": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "questions": { "type": "array", "items": { "type": "string" } },
              "evidence": { "type": "array", "items": { "type": "string" } },
              "nonconformities": { "type": "array", "items": { "type": "string" } }
            }
          },
          "mapping": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "nist_800_53": { "type": "array", "items": { "type": "string" } },
              "note": { "type": "string" }
            }
          },
          "iso27001": { "type": "string" },
          "concepts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "rel"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "rel": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        }
      }
    }
  }
}
